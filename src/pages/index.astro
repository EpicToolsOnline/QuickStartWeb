---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>QuickStart</title>
    <meta name="description" content="Pick your apps, get one exe, install everything. An open source alternative to Ninite." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="top-bar">
      <Logo />
      <p class="powered-by">Powered by <a href="https://epictoolsonline.com" class="brand">EpicToolsOnline</a></p>
    </div>

    <main>
      <p class="intro">
        QuickStart is an open source, free alternative to Ninite. Ninite lets you tick a
        list of apps and get one installer that sets them all up silently, no clicking
        through a wizard for each one, no toolbars, no bundled junk. QuickStart does the
        same thing, but the code is fully open, anyone can see exactly what it does, and
        anyone can add apps or fix bugs. Pick what you want below, hit download, and run
        the file it gives you, that single exe installs everything you picked using
        Windows' own package manager (winget) in the background.
      </p>

      <label for="app-search" class="sr-only">Search apps</label>
      <input
        type="search"
        class="input search-bar"
        placeholder="e.g. discord, browser, editor..."
        id="app-search"
      />

      <div class="category-filters" role="group" aria-label="Filter by category">
        <button type="button" class="category-pill" data-category="" aria-pressed="true">All</button>
        {categories.map((category) => (
          <button type="button" class="category-pill" data-category={category.name.toLowerCase()} aria-pressed="false">
            {category.name}
          </button>
        ))}
      </div>

      {categories.map((category) => (
        <section class="category" data-category-section={category.name.toLowerCase()}>
          <h2>{category.name}</h2>
          <div class="app-grid">
            {category.apps.map((app) => (
              <label
                class="card app-option"
                data-name={app.name.toLowerCase()}
                data-desc={app.desc.toLowerCase()}
                data-category={category.name.toLowerCase()}
              >
                <input type="checkbox" class="app-checkbox" data-token={app.token} />
                <span class="checkmark"></span>
                <span class="app-text">
                  <span class="app-name">{app.name}</span>
                  <span class="app-desc">{app.desc}</span>
                </span>
              </label>
            ))}
          </div>
        </section>
      ))}

      <p id="no-results" class="no-results" hidden>Nothing matches that search.</p>

      <button id="generate" class="button" disabled>
        Pick at least one app
      </button>
    </main>

    <Footer />
  </body>
</html>

<style>
  .top-bar {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-5) var(--space-4) 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .powered-by {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .powered-by .brand {
    color: var(--color-accent);
    font-weight: 700;
    text-decoration: none;
  }

  .powered-by .brand:hover {
    text-decoration: underline;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-5) var(--space-4);
  }

  .intro {
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
    line-height: 1.6;
  }

  .search-bar {
    width: 100%;
    font-size: 1.1rem;
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-3);
  }

  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .category-pill {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--color-surface-raised);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
  }

  .category-pill:hover {
    color: var(--color-text);
  }

  .category-pill[aria-pressed="true"] {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .category {
    margin-bottom: var(--space-6);
  }

  .category h2 {
    font-size: 1rem;
    margin-bottom: var(--space-3);
    color: var(--color-text-muted);
  }

  .app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-3);
  }

  .app-option {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    cursor: pointer;
    transition: border-color 0.15s ease;
  }

  .app-option:hover {
    border-color: var(--color-accent);
  }

  .app-checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .checkmark {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    position: relative;
  }

  .app-checkbox:checked + .checkmark {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .app-checkbox:checked + .checkmark::after {
    content: "";
    position: absolute;
    left: 6px;
    top: 2px;
    width: 5px;
    height: 10px;
    border: solid var(--color-accent-text);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .app-checkbox:focus-visible + .checkmark {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .app-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .app-name {
    font-weight: 600;
  }

  .app-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .no-results {
    color: var(--color-text-muted);
    text-align: center;
    padding: var(--space-5) 0;
  }

  #generate {
    width: 100%;
    margin-top: var(--space-4);
  }

  #generate:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script>
  const searchInput = document.getElementById("app-search") as HTMLInputElement;
  const pills = document.querySelectorAll<HTMLButtonElement>(".category-pill");
  const cards = document.querySelectorAll<HTMLElement>(".app-option");
  const sections = document.querySelectorAll<HTMLElement>(".category");
  const noResults = document.getElementById("no-results") as HTMLElement;

  let activeCategory = "";

  function applyFilters() {
    const query = searchInput.value.trim().toLowerCase();
    let anyVisible = false;

    for (const card of cards) {
      const haystack = `${card.dataset.name} ${card.dataset.desc}`;
      const matchesSearch = query.length === 0 || haystack.includes(query);
      const matchesCategory = activeCategory === "" || card.dataset.category === activeCategory;
      const visible = matchesSearch && matchesCategory;
      card.hidden = !visible;
      if (visible) anyVisible = true;
    }

    for (const section of sections) {
      const sectionCards = section.querySelectorAll<HTMLElement>(".app-option");
      const hasVisibleCard = Array.from(sectionCards).some((c) => !c.hidden);
      section.hidden = !hasVisibleCard;
    }

    noResults.hidden = anyVisible;
  }

  searchInput.addEventListener("input", applyFilters);

  for (const pill of pills) {
    pill.addEventListener("click", () => {
      activeCategory = pill.dataset.category ?? "";
      for (const p of pills) p.setAttribute("aria-pressed", String(p === pill));
      applyFilters();
    });
  }

  const checkboxes = document.querySelectorAll<HTMLInputElement>(".app-checkbox");
  const button = document.getElementById("generate") as HTMLButtonElement;

  function updateButton() {
    const picked = Array.from(checkboxes)
      .filter((box) => box.checked)
      .map((box) => box.dataset.token);

    if (picked.length === 0) {
      button.disabled = true;
      button.textContent = "Pick at least one app";
      button.removeAttribute("data-href");
      return;
    }

    button.disabled = false;
    button.textContent = `Download QuickStart (${picked.length} apps)`;
    button.setAttribute(
      "data-href",
      `/api/download?apps=${picked.map(encodeURIComponent).join(",")}`
    );
  }

  checkboxes.forEach((box) => box.addEventListener("change", updateButton));

  button.addEventListener("click", () => {
    const href = button.getAttribute("data-href");
    if (href) window.location.href = href;
  });
</script>